{
  "id": "plano-sono-app",
  "name": "Plano de Sono — Atleta de Alto Nível",
  "short_name": "Plano de Sono",
  "description": "Protocolo científico de sono para atletas de elite, focado em recuperação muscular e alta performance cognitiva.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override":["window-controls-overlay", "tabbed", "standalone"],
  "orientation": "portrait",
  "background_color": "#07090f",
  "theme_color": "#c4b5fd",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories":["sports", "health", "lifestyle"],
  "iarc_rating_id": "e84ca3a9-7033-40e9-a3c3-163e7c81d3f3",
  
  "related_applications":[
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.planosono.app",
      "id": "com.planosono.app"
    },
    {
      "platform": "windows",
      "url": "https://www.microsoft.com/store/apps/9NBLGGH4XXXX",
      "id": "9NBLGGH4XXXX"
    }
  ],
  "prefer_related_applications": false,
  
  "scope_extensions":[
    {
      "type": "origin",
      "origin": "https://lucaspombal9-arch.github.io"
    },
    {
      "type": "origin",
      "origin": "https://github.com"
    }
  ],

  "file_handlers":[
    {
      "action": "./",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],

  "widgets":[
    {
      "name": "Widget de Sono",
      "description": "Acompanhe seu progresso de sono",
      "tag": "sono-widget",
      "ms_ac_template": "./widgets/template.json",
      "data": "./widgets/data.json",
      "type": "application/json"
    }
  ],

  "note_taking": {
    "new_note_url": "./?new-note"
  },

  "tab_strip": {
    "new_tab_button": {
      "url": "./"
    }
  },

  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "protocol_handlers":[
    {
      "protocol": "web+sono",
      "url": "./?link=%s"
    }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "icons":[
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots":[
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "App Mobile"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "App Desktop"
    }
  ],
  "shortcuts":[
    {
      "name": "Abrir Plano",
      "url": "./index.html",
      "icons":[
        {
          "src": "icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
}
